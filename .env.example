# ============================================================
# Multi-Agent System — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Only ANTHROPIC_API_KEY is required if using the default model.

# --- LLM Provider API Keys (set the one matching your model) ---
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# --- LLM Model Selection ---
# Default model for all agents. Uses LiteLLM format: "provider/model-name"
# Examples:
#   anthropic/claude-sonnet-4-20250514   (Anthropic, default)
#   gpt-4o                                (OpenAI)
#   ollama/llama3                          (local Ollama)
LLM_MODEL=anthropic/claude-sonnet-4-20250514

# Per-agent overrides (optional — defaults to LLM_MODEL)
# ORCHESTRATOR_MODEL=anthropic/claude-sonnet-4-20250514
# EXECUTOR_MODEL=anthropic/claude-sonnet-4-20250514
# NAVIGATOR_MODEL=anthropic/claude-sonnet-4-20250514
