# ============================================================
# Multi-agent system — environment variables (template)
# ============================================================
# Copy to .env and edit.

# --- LLM model selection ---
# Any LiteLLM-supported model works for the orchestrator and sub-agents.
# Pick ONE block below (uncomment exactly one LLM_MODEL line).

# --- Option A: Anthropic Claude (frontier; strong baseline) ---
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=anthropic/claude-opus-4-7
# Or a smaller Anthropic model:
# LLM_MODEL=anthropic/claude-sonnet-4-20250514

# --- Option B: OpenAI-compatible endpoint (vLLM / Ollama / LocalAI / etc.) ---
# Set OPENAI_API_BASE to your endpoint. The literal string "none" is
# accepted as the API key by most OpenAI-compatible servers that do not
# enforce auth. Note: multi-agent tends to push tool-using LLMs harder
# than skill-based does (each sub-agent has its own MCP tool surface);
# small open-weights models may struggle here even if they suffice for
# skill-based.
# OPENAI_API_BASE=http://<your-vllm-host>:<port>/v1
# OPENAI_API_KEY=none
# LLM_MODEL=openai/<model-id-as-served-by-your-endpoint>

# --- Option C: OpenAI directly ---
# OPENAI_API_KEY=sk-...
# LLM_MODEL=openai/gpt-4o

# --- Per-agent overrides (optional) ---
# Each falls back to LLM_MODEL if unset. Useful for using a stronger
# model on the orchestrator and a cheaper one on the sub-agents.
# ORCHESTRATOR_MODEL=
# EXECUTOR_MODEL=
# APPROACH_MODEL=
